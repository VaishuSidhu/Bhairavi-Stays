<script>
document.addEventListener('DOMContentLoaded', function () {

  // Fix: Force multiple file upload on guest ID field
  var fileInputs = document.querySelectorAll(
    '.hotel-booking-form input[type="file"]'
  );
  fileInputs.forEach(function (input) {
    input.setAttribute('multiple', 'multiple');
    input.removeAttribute('accept'); // remove if it blocks selection
    input.setAttribute(
      'accept',
      '.jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf'
    );
  });

  // Fix: Open date picker on full field click (not just icon)
  document.querySelectorAll('.hotel-booking-form input[type="date"]')
    .forEach(function (input) {
      input.addEventListener('click', function () {
        try { this.showPicker(); } catch (e) {}
      });
      input.style.cursor = 'pointer';
    });

});
</script>

</html>


