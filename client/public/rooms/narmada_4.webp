@font-face{font-family:"DM Sans";font-style:normal;font-weight:100 900;font-display:fallback;}
</style>
    <style type="text/css">
        body.solace_elementor_header_footer .container,
        body.solace_elementor_canvas .container {
            max-width: none !important;
            width: 100% !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
            margin: 0 !important;
        }

        body.solace_elementor_header_footer .elementor,
        body.solace_elementor_canvas .elementor {
            width: 100%;
        }
        body.theme-solace span.onsale {
            z-index: 2;
        }
        body.solace-sitebuilder-singleproduct.single-product .container.shop-container .woocommerce-message {
            margin-bottom: 0;
        }
        body.solace-sitebuilder-singleproduct.single-product .container.shop-container {
            padding-left: 0;
            padding-right: 0;
        }
    </style>
    		<style id="wp-custom-css">
			span.vbo-listing-amenity-icon img {
  width: 36px !important;
  height: 36px !important;
  max-width: 36px !important;
  max-height: 36px !important;
  object-fit: contain !important;
}

span.vbo-listing-amenity-icon {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  width: 36px !important;
  height: 36px !important;
  flex-shrink: 0 !important;
}

.vbo-listing-amenity {
  display: inline-flex !important;
  align-items: center !important;
  gap: 8px !important;
  margin: 6px 12px !important;
  writing-mode: horizontal-tb !important;
  white-space: nowrap !important;
}

.vbo-listing-amenity-name {
  font-size: 13px !important;
  writing-mode: horizontal-tb !important;
  white-space: nowrap !important;
  letter-spacing: normal !important;
}

.vbo-listing-amenities {
  display: flex !important;
  flex-wrap: wrap !important;
  justify-content: center !important;
  align-items: center !important;
  gap: 10px 20px !important;
  width: 100% !important;
}

.vbo-listing-amenities-wrap h4 {
  text-align: center !important;
}

.page-header h1 {
  font-size: 36px !important;
}

/* Option 3 - targets all hero headings */
.elementor-widget-heading .elementor-heading-title {
  font-size: 36px !important;
}

/* Reduce the hero heading size */
.boxes-header .the-title h1 {
    font-size: 48px !important; /* Adjust this value as needed */
    margin-bottom: 0;
}

/* Reduce the excessive padding/height of the hero section */
.nv-post-cover, 
.boxes-header .cover {
    min-height: 100px !important; /* Adjusts the overall height */
    padding-top: 20px !important;
    padding-bottom: 20px !important;
}

/* Ensure the text container doesn't force extra height */
.boxes-header .text {
    padding: 20px 0 !important;
}

/* ── Hotel Booking Form ─────────────────────────── */
.hotel-booking-form {
  max-width: 720px;
  margin: 0 auto;
  font-family: inherit;
}

.hotel-booking-form .form-row {
  margin-bottom: 16px;
}

/* Tightest possible gap between label and field */
.hotel-booking-form label {
  display: block;
  font-weight: 600;
  margin-bottom: 2px;
  line-height: 1.3;
  color: #222;
}

.hotel-booking-form .required {
  color: #e53935;
  margin-left: 2px;
}

/* ── Name row ───────────────────────────────────── */
.hotel-booking-form .name-fields {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 0;
}

.hotel-booking-form .name-col {
  flex: 1;
  min-width: 140px;
  display: flex;
  flex-direction: column;
}

/* ── Emergency fields ───────────────────────────── */
.hotel-booking-form .emergency-fields {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 0;
}

.hotel-booking-form .emergency-col {
  flex: 1;
  min-width: 140px;
  display: flex;
  flex-direction: column;
}

.hotel-booking-form .field-label {
  font-size: 12px;
  color: #888;
  margin-top: 2px;
}

/* ── All inputs and selects ─────────────────────── */
.hotel-booking-form input[type="text"],
.hotel-booking-form input[type="tel"],
.hotel-booking-form input[type="date"],
.hotel-booking-form select {
  width: 100%;
  padding: 9px 12px;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 14px;
  color: #333;
  background: #fff;
  box-sizing: border-box;
  transition: border-color 0.2s;
  cursor: pointer;
}

.hotel-booking-form input:focus,
.hotel-booking-form select:focus {
  border-color: #b08850;
  outline: none;
  box-shadow: 0 0 0 3px rgba(176, 136, 80, 0.15);
}

/* ── Date + Time side by side ───────────────────── */
.hotel-booking-form .date-time-row {
  display: flex;
  gap: 10px;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 0;
}

.hotel-booking-form .date-time-row input[type="date"] {
  flex: 1 1 160px;
  width: auto;
}

.hotel-booking-form .date-time-row select {
  flex: 1 1 130px;
  width: auto;
}

/* ── Guest Count ────────────────────────────────── */
.hotel-booking-form .guest-count-fields {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 0;
}

.hotel-booking-form .guest-count-col {
  flex: 1;
  min-width: 150px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.hotel-booking-form .guest-count-label {
  font-weight: 600;
  font-size: 13px;
  color: #333;
  margin-bottom: 2px;
}

.hotel-booking-form .age-note {
  font-weight: 400;
  font-size: 11px;
  color: #888;
}

.hotel-booking-form .guest-count-col select {
  width: 100%;
  padding: 9px 12px;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 14px;
  color: #333;
  background: #fff;
  box-sizing: border-box;
  transition: border-color 0.2s;
  appearance: auto;
}

.hotel-booking-form .guest-count-col select:focus {
  border-color: #b08850;
  outline: none;
  box-shadow: 0 0 0 3px rgba(176, 136, 80, 0.15);
}

/* ── Hints ──────────────────────────────────────── */
.hotel-booking-form .field-hint {
  display: block;
  font-size: 11px;
  color: #999;
  margin-top: 3px;
  line-height: 1.4;
}

/* ── File upload ────────────────────────────────── */
.hotel-booking-form input[type="file"] {
  padding: 6px 0;
  font-size: 13px;
  cursor: pointer;
}

/* ── Submit ─────────────────────────────────────── */
.hotel-booking-form .submit-row {
  margin-top: 24px;
}

.hotel-booking-form input[type="submit"] {
  background-color: #b08850;
  color: #fff;
  border: none;
  padding: 12px 34px;
  font-size: 15px;
  font-weight: 600;
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.2s;
}

.hotel-booking-form input[type="submit"]:hover {
  background-color: #8c6a38;
}

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 540px) {
  .hotel-booking-form .name-fields,
  .hotel-booking-form .emergency-fields,
  .hotel-booking-form .guest-count-fields,
  .hotel-booking-form .date-time-row {
    flex-direction: column;
  }
}

.hotel-booking-form br {
  display: none !important;
}

.hotel-booking-form .wpcf7-form-control-wrap {
  display: block;
  margin: 0 !important;
  padding: 0 !important;
}

.hotel-booking-form label {
  display: block;
  font-weight: 600;
  margin-bottom: 2px !important;
  margin-top: 0 !important;
  padding: 0 !important;
  line-height: 1.2;
  color: #222;
}

.hotel-booking-form .form-row {
  margin-bottom: 14px;
  padding: 0;
}

.hotel-booking-form p {
  margin: 0 !important;
  padding: 0 !important;
}

.hotel-booking-form .date-time-row {
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  gap: 10px !important;
  flex-wrap: nowrap !important;
}

.hotel-booking-form .date-time-row * {
  display: inline-flex !important;
  flex: 1 !important;
  width: 100% !important;
}

.hotel-booking-form .date-time-row input[type="date"],
.hotel-booking-form .date-time-row select {
  display: block !important;
  width: 100% !important;
  flex: 1 !important;
  padding: 9px 12px !important;
  border: 1px solid #ccc !important;
  border-radius: 6px !important;
  font-size: 14px !important;
  color: #333 !important;
  background: #fff !important;
  box-sizing: border-box !important;
}

.wpcf7-form-control-wrap.checkin-date,
.wpcf7-form-control-wrap.checkin-time,
.wpcf7-form-control-wrap.checkout-date,
.wpcf7-form-control-wrap.checkout-time {
  display: flex !important;
  flex: 1 !important;
  margin: 0 !important;
  padding: 0 !important;
}

@media (max-width: 480px) {
  .hotel-booking-form .date-time-row {
    flex-direction: column !important;
  }
}

.hotel-booking-form .name-fields,
.hotel-booking-form .emergency-fields,
.hotel-booking-form .guest-count-fields {
  display: flex;
  gap: 16px;
